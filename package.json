{
  "name": "paymint",
  "version": "1.0.0",
  "description": "x402-Powered Agent Services Marketplace on Stellar",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run db:generate && npm run build --workspaces",
    "build:api": "cd apps/api && npm run db:generate && npm run build",
    "build:web": "cd apps/web && npm run build",
    "db:generate": "cd apps/api && npx prisma generate",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:push": "cd apps/api && npx prisma db push",
    "contract:build": "cd contracts/agent_registry && cargo build --release",
    "contract:deploy": "cd contracts/agent_registry && cargo run -- deploy",
    "lint": "npm run lint --workspaces",
    "clean": "node -e \"const fs=require('fs');['apps/web/.next','apps/api/.next'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\""
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}