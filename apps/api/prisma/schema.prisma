// Prisma Schema for AgentPay
// Updated: 2026-04-09

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AGENT MODEL - AI agents registered in the marketplace
// ============================================================================
model Agent {
  id                String    @id @default(uuid())
  ownerAddress      String    // Wallet address (allows multiple agents per wallet)
  name              String
  description       String?
  status            String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  
  // Agent configuration for buyers
  apiEndpoint       String?   // The base URL where the agent's API is hosted
  apiKey            String?   // API key for authentication
  webhookUrl        String?   // Webhook URL for notifications
  documentationUrl  String?   // Link to documentation
  
  // Capabilities and pricing
  capabilities      String[]  // Array of capability tags
  pricingModel      String    @default("PER_CALL") // PER_CALL, SUBSCRIPTION, ENTERPRISE
  pricePerCall      Float?
  pricePerMonth     Float?
  
  // Additional info
  logoUrl           String?
  websiteUrl        String?
  supportEmail      String?
  termsOfServiceUrl String?
  
  // Ratings
  rating            Float     @default(0)
  ratingCount       Int       @default(0)
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================================================
// SERVICE MODEL - Services offered by agents
// ============================================================================
model Service {
  id             String    @id @default(uuid())
  agentId        String    // Reference to agent (no FK to avoid join issues)
  name           String
  description    String?
  serviceType    String    @default("CUSTOM") // CUSTOM, PREMIUM, ENTERPRISE
  pricePerCall   Float
  currency       String    @default("XLM") // XLM, USDC
  isActive       Boolean   @default(true)
  totalCalls     Int       @default(0)
  
  // Service-specific configuration
  endpoint       String?   // Specific endpoint path
  method         String    @default("POST") // HTTP method
  rateLimit      Int?      // Calls per minute
  timeout        Int?      // Request timeout in seconds
  retryPolicy    String?   // JSON string
  
  // Response info
  responseFormat String?   // JSON, XML, etc.
  schema         String?   // JSON schema
  
  // Usage documentation
  usageExamples  String[]  // Array of usage examples
  
  // Timestamps
  createdAt      DateTime  @default(now())
}

// ============================================================================
// PAYMENT MODEL - Payment/escrow transactions
// ============================================================================
model Payment {
  id               String    @id @default(uuid())
  serviceId        String    // Reference to service (no FK to avoid join issues)
  buyerAddress     String    // Buyer wallet address
  sellerAddress    String    // Seller wallet address
  amount           Float
  currency         String
  status           String    @default("PENDING") // PENDING, ESCROW_CREATED, COMPLETED, FAILED, REFUND_REQUESTED, REFUNDED, DISPUTED
  transactionHash  String?   // Stellar transaction hash
  escrowId         String?   // Escrow ID
  refundReason     String?   // Reason for refund request
  disputeReason   String?   // Reason for dispute
  disputeOpenedAt  DateTime? // When dispute was opened
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ============================================================================
// TRANSACTION MODEL - Stellar blockchain transactions
// ============================================================================
model Transaction {
  id         String   @id @default(uuid())
  hash       String   @unique // Transaction hash
  type       String   // PAYMENT, ESCROW, RELEASE
  fromAddress String
  toAddress   String
  amount     Float
  currency   String
  status     String   @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt  DateTime @default(now())
}

// ============================================================================
// REVIEW MODEL - Agent ratings and reviews from buyers
// ============================================================================
model Review {
  id           String   @id @default(uuid())
  agentId      String   // Reference to agent
  buyerAddress String   // Buyer wallet address
  rating      Int      // 1-5 rating
  comment     String?
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  // Unique constraint: one review per buyer per agent
  @@unique([agentId, buyerAddress])
}

// ============================================================================
// NOTIFICATION MODEL - User notifications
// ============================================================================
model Notification {
  id           String   @id @default(uuid())
  userAddress  String   // User wallet address
  type        String   // Notification type
  title       String   // Notification title
  message     String   // Notification message
  paymentId   String?  // Related payment ID
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
