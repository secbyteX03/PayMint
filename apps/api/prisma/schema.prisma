generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id          String   @id @default(uuid())
  ownerAddress String  @unique
  name        String
  description String
  status      AgentStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  services    Service[]
}

model Service {
  id            String      @id @default(uuid())
  agentId       String
  agent         Agent       @relation(fields: [agentId], references: [id])
  name          String
  description   String
  serviceType   ServiceType @default(CUSTOM)
  pricePerCall Decimal     @db.Decimal(15, 7)
  currency      String      @default("USDC")
  isActive      Boolean     @default(true)
  totalCalls    Int         @default(0)
  createdAt     DateTime    @default(now())
  payments      Payment[]
}

model Payment {
  id              String        @id @default(uuid())
  serviceId       String
  service         Service       @relation(fields: [serviceId], references: [id])
  buyerAddress    String
  sellerAddress   String
  amount          Decimal       @db.Decimal(15, 7)
  currency        String
  status          PaymentStatus @default(PENDING)
  transactionHash String?
  escrowId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Transaction {
  id              String   @id @default(uuid())
  hash            String   @unique
  type            TransactionType
  fromAddress     String
  toAddress       String
  amount          Decimal  @db.Decimal(15, 7)
  currency        String
  status          TransactionStatus @default(PENDING)
  createdAt       DateTime @default(now())
}

enum AgentStatus {
  REGISTERED
  ACTIVE
  SUSPENDED
  PAUSED
}

enum ServiceType {
  DATA_ANALYSIS
  API_ACCESS
  CONTENT_GENERATION
  RESEARCH
  CUSTOM
}

enum PaymentStatus {
  PENDING
  ESCROW_CREATED
  COMPLETED
  REFUNDED
  FAILED
}

enum TransactionType {
  PAYMENT
  ESCROW_CREATE
  ESCROW_RELEASE
  ESCROW_REFUND
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}