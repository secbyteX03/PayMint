# Ollama Configuration for PayMint Playground
# Install Ollama from https://ollama.com and run it locally

# Default endpoint - usually localhost:11434
NEXT_PUBLIC_OLLAMA_ENDPOINT=http://localhost:11434

# Default model - use 'llama3.2', 'mistral', or other models
# Run 'ollama list' to see available models
NEXT_PUBLIC_OLLAMA_MODEL=llama3.2